Checks: >-
  -*,
  clang-analyzer-*,
  bugprone-*,
  performance-*,
  portability-*,
  modernize-use-nullptr,
  modernize-use-override,
  readability-container-size-empty
WarningsAsErrors: ''
HeaderFilterRegex: '^(src/libslic3r/(FilamentRoutingPlan|FilamentPlacementOptimizer)|src/slic3r/GUI/multiace)/'
FormatStyle: file
